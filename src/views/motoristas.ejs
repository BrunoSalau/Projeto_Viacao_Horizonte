<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Motoristas</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="/css/motoristas.css">
</head>

<body>

    <!-- Botão hambúrguer (visível apenas em mobile) -->
    <button class="hamburger-btn" id="hamburgerBtn" aria-label="Abrir menu">
        <span></span>
        <span></span>
        <span></span>
    </button>

    <!-- Overlay (mobile) -->
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <main class="container-fluid min-vh-100 px-0">
        <div class="row flex-nowrap g-0">

            <!-- Sidebar -->
            <aside id="barraLateral" class="min-vh-100 bg-dark2 sidebar">

                <!-- Botão fechar (mobile) -->
                <button class="close-btn" id="closeBtn" aria-label="Fechar menu">&#10005;</button>

                <article class="sidebar-header p-4 m-1">
                    <img class="img-fluid mb-3" id="img-vh" src="img/icons/vh.png" alt="Viação Horizonte">
                    <div class="sidebar-brand-text">
                        <h1 class="text-white p-0 m-0 fw-normal fs-6">V I A Ç Ã O</h1>
                        <h1 class="text-yellow p-0 m-0 fw-bold fs-6">H O R I Z O N T E</h1>
                        <p class="text-white2 p-0 m-0 mt-3 fs-7">Transportando destinos</p>
                        <p class="text-white2 p-0 m-0 fs-7">conectando você</p>
                    </div>
                </article>

                <section class="bg-dark3 rounded-4 fs-6 sidebar-nav-section" id="bar">
                    <nav>
                        <ul class="nav flex-column">

                            <li class="nav-item">
                                <a class="nav-link text-white p-0 m-3 nav-item-link" href="/motoristas">
                                    <img class="img-fluid nav-icon" src="img/icons/user (2).png" alt="Motoristas">
                                    <span class="nav-label">Motoristas</span>
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link p-0 m-3 text-white nav-item-link" href="/veiculo">
                                    <div class="troca-imagem">
                                        <img class="img-fluid img nav-icon" src="img/icons/bus (2).png" alt="Veículos">
                                    </div>
                                    <span class="nav-label">Veículos</span>
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-white p-0 m-3 nav-item-link" href="#">
                                    <img class="img-fluid nav-icon" src="img/icons/rotes (2).png" alt="Rotas">
                                    <span class="nav-label">Rotas</span>
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-white p-0 m-3 nav-item-link" href="#">
                                    <img class="img-fluid nav-icon" src="img/icons/viagem (2).png" alt="Viagens">
                                    <span class="nav-label">Viagens</span>
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-white p-0 m-3 nav-item-link" href="#">
                                    <img class="img-fluid nav-icon" src="img/icons/chave-inglesa (2).png"
                                        alt="Manutenções">
                                    <span class="nav-label">Manutenções</span>
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-white p-0 m-3 nav-item-link" href="#">
                                    <img class="img-fluid nav-icon" src="img/icons/gasolina (2).png"
                                        alt="Abastecimento">
                                    <span class="nav-label">Abastecimento</span>
                                </a>
                            </li>
                        </ul>
                    </nav>
                </section>

            </aside>

            <!-- Conteúdo principal -->
            <section class="main-content bg-light flex-grow-1">

                <!-- TOPBAR -->
                <div class="topbar">
                    <div class="topbar-left">
                        <h2 class="topbar-title">Motoristas</h2>
                    </div>

                    <form action="get">
                        <div class="topbar-search">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#aaa" stroke-width="2"
                                stroke-linecap="round">
                                <circle cx="11" cy="11" r="8" />
                                <line x1="21" y1="21" x2="16.65" y2="16.65" />
                            </svg>
                            <input type="text" id="campoPesquisa" placeholder="Pesquisar motorista...">
                            <button type="button" class="kbd-hint btn btn-light" id="btnPesquisar">Pesquisar</button>
                        </div>
                    </form>

                    <div class="topbar-right">
                        <div class="user-info">
                            <div class="user-avatar-placeholder">awa</div>
                            <div class="sidebar-brand-text">
                                <div class="user-name">Matheus Oliveira</div>
                                <div class="user-role">Supervisor</div>
                            </div>
                        </div>
                        <button id="btnLogout" class="btn btn-outline-dark btn-sm">Sair</button>
                    </div>
                </div>

                <!-- TOOLBAR -->
                <div class="vehicles-toolbar">
                    <button id="abrirModal" class="btn-add-vehicle">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2.5" stroke-linecap="round">
                            <line x1="12" y1="5" x2="12" y2="19" />
                            <line x1="5" y1="12" x2="19" y2="12" />
                        </svg>
                        Adicionar Motorista
                    </button>
                    <button id="abrirModalEx" class="btn-dark btn">
                        Apagar Motorista
                    </button>
                    <button id="abrirModalEdit" class="btn-outline-dark btn">
                        Editar Motorista
                    </button>
                </div>

                <!-- GRID DE MOTORISTAS -->
                <div class="vehicles-grid" id="gridMotoristas">
                    <!-- Cards inseridos via JS -->
                </div>


                <!-- ===================== MODAL: ADICIONAR =====================
                     Rota: POST /usuario/criarUsuario
                     O controller cria o usuário (tipo Motorista) e o motorista
                     em uma única operação. Por isso o form inclui o campo senha.
                ================================================================ -->
                <div id="modal" class="modal">
                    <div class="modal-content">
                        <span id="fecharModal">&times;</span>
                        <h2 class="text-center">Adicionar Motorista</h2>
                        <form class="text-center" id="formAdicionar">
                            <p>Preencha os dados para criar o acesso e o cadastro do motorista.</p>

                            <input type="text" name="nome" class="form-control my-3"
                                placeholder="Nome completo..." required>

                            <input type="text" name="cpf" class="form-control my-3"
                                placeholder="CPF (somente números)..." required>

                            <input type="password" name="senha" class="form-control my-3"
                                placeholder="Senha de acesso..." required>

                            <input type="text" name="cnh" class="form-control my-3"
                                placeholder="CNH..." required>

                            <input type="text" name="telefone" class="form-control my-3"
                                placeholder="Telefone..." required>

                            <button type="submit" class="btn btn-warning mt-2">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="2.5" stroke-linecap="round">
                                    <line x1="12" y1="5" x2="12" y2="19" />
                                    <line x1="5" y1="12" x2="19" y2="12" />
                                </svg>
                                Adicionar Motorista
                            </button>
                        </form>
                    </div>
                </div>


                <!-- ===================== MODAL: EXCLUIR =====================
                     Rota: POST /usuario/deletarUsuario
                     O controller busca o CPF, identifica que é Motorista e
                     remove os registros de usuário e motorista juntos.
                ============================================================= -->
                <div id="modalEx" class="modal">
                    <div class="modal-content">
                        <span id="fecharModalEx">&times;</span>
                        <h2 class="text-center mb-3">Apagar Motorista</h2>
                        <form class="text-center" id="formExcluir">
                            <p>Informe o CPF do motorista. O acesso ao sistema e o cadastro serão removidos.</p>
                            <input type="text" placeholder="CPF do motorista..." name="cpf"
                                class="form-control" required>
                            <br>
                            <button type="submit" class="btn btn-warning" id="excluirBtn">
                                Excluir Motorista
                            </button>
                        </form>
                    </div>
                </div>


                <!-- ===================== MODAL: EDITAR =====================
                     Rota: PUT /motoristas/atualizarMotorista
                     Atualiza apenas os dados do motorista (nome, cnh, telefone).
                     Não altera CPF nem senha do usuário.
                ============================================================= -->
                <div id="modalEdit" class="modal">
                    <div class="modal-content">
                        <span id="fecharModalEdit">&times;</span>
                        <h2 class="text-center mb-3">Editar Motorista</h2>
                        <form class="text-center" id="formEditar">
                            <p>Informe o CPF para localizar o motorista e preencha os campos a alterar.</p>

                            <input type="text" name="cpf" class="form-control my-3"
                                placeholder="CPF (para localizar)..." required>

                            <input type="text" name="nome" class="form-control my-3"
                                placeholder="Novo nome...">

                            <input type="text" name="cnh" class="form-control my-3"
                                placeholder="Nova CNH...">

                            <input type="text" name="telefone" class="form-control my-3"
                                placeholder="Novo telefone...">

                            <button type="submit" class="btn btn-warning mt-2">
                                Salvar Alterações
                            </button>
                        </form>
                    </div>
                </div>


                <!-- ===================== MODAL: FEEDBACK ===================== -->
                <div id="erroPlaca" class="modal">
                    <div id="bgPop" class="modal-content">
                        <span id="fecharErroPlaca">&times;</span>
                        <h2 class="text-center mb-3 text-white" id="msgTitulo"></h2>
                        <p class="text-center text-white" id="msgErro"></p>
                        <button class="btn btn-dark text-light" id="fecharErroPlacaBtn">
                            Fechar
                        </button>
                    </div>
                </div>

            </section>
        </div>
    </main>

    <script src="js/motoristas.js"></script>
</body>

</html>
