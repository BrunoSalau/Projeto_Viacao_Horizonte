<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="mh-100 overflow-auto">
    <main class="container-fluid">
        <div class="row d-flex justify-content-center align-items-center vh-100">
            <div class="col-3"></div>
            <div class="col-3 boxShadow border border-dark rounded p-3 bg-dark2">


                <form action="/login" method="post" class="formulario">
                    <article id="boxlogo" class="d-flex justify-content-center align-items-center">
                        <img id="logo" class="img-fluid border w-75 rounded-circle img-glow border-warning" src="/img/ChatGPT_Image_14_de_mai._de_2026__12_28_08-removebg-preview.png" alt="">
                    </article>
                    <article>
                        <label for="cpf" class="text-start mt-3 text-warning fw-bold">CPF</label>
                        <input type="text" id="cpf" name="cpfInput" maxlength="14" class="form-control border-2" placeholder="Digite seu cpf...">
                        <p id="msgCpf" class="text-danger px-2 fw-bold"><br></p>
                        <label for="senha" class="text-start text-warning fw-bold">SENHA</label>
                        <article class="position-relative">    
                            <input type="password" name="senhaInput" id="senha" class="form-control border-2" placeholder="Digite sua senha...">
                            <button type="button" id="mostrarSenha" class="btn position-absolute top-50 end-0 translate-middle-y border-0 bg-transparent">
                                
                            </button>
                        </article>
                        
                        <p id="msgSenha" class="text-danger px-2 fw-bold"><br></p>
                        
                    </article>
                    <article class="container-fluid mt-5 mb-3">
                        <button id="botao1" class="d-flex w-100 btn btn-warning">
                            <div class="w-25"></div>
                            <div class="w-100 text-center fw-bold">LOGAR</div>
                            <div class="w-25 text-end">⭢</div>
                        </button>
                    </article>
                </form>



            </div>
            <div class="col-3"></div>
        </div>
    </main>


    <script src="js/script.js"></script>
</body>
</html>