<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Viação Horizonte - Login</title>
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- CSS Customizado -->
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="login-body">
    <div class="login-container">
        <div class="login-card">
            <!-- Logo -->
            <div class="logo-container">
                <img src="/img/Logo_circle.png" alt="Viação Horizonte" class="logo-image">
            </div>

            <!-- Formulário -->
            <form id="loginForm" method="POST" action="/login">
                <!-- CPF -->
                <div class="mb-4">
                    <label for="cpf" class="form-label">
                        <i class="fas fa-user"></i> CPF
                    </label>
                    <input 
                        type="text" 
                        class="form-control login-input" 
                        id="cpf" 
                        name="cpf" 
                        placeholder="Digite seu CPF"
                        required
                    >
                </div>

                <!-- Senha -->
                <div class="mb-4">
                    <label for="password" class="form-label">
                        <i class="fas fa-lock"></i> Senha
                    </label>
                    <div class="password-wrapper">
                        <input 
                            type="password" 
                            class="form-control login-input" 
                            id="password" 
                            name="password" 
                            placeholder="Digite sua senha"
                            required
                        >
                        <button type="button" class="btn-password-toggle" id="togglePassword">
                            <i class="fas fa-eye"></i>
                        </button>
                    </div>
                </div>

                <!-- Opções -->
                <div class="d-flex justify-content-between align-items-center mb-4 options-container">
                    <div class="form-check">
                        <input 
                            class="form-check-input" 
                            type="checkbox" 
                            id="remember" 
                            name="remember"
                        >
                        <label class="form-check-label" for="remember">
                            Lembrar meu acesso
                        </label>
                    </div>
                    <a href="/forgot-password" class="forgot-password-link">
                        Esqueceu sua senha?
                    </a>
                </div>

                <!-- Botão de Login -->
                <button type="submit" class="btn btn-login w-100">
                    LOGAR
                    <i class="fas fa-arrow-right"></i>
                </button>
            </form>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- Font Awesome (para ícones) -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/js/all.min.js"></script>
    
    <!-- JavaScript Customizado -->
    <script src="/js/login.js"></script>
</body>
</html>
