<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Viagens</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="/css/viagens.css">
</head>

<body>

    <!-- Botão hambúrguer (visível apenas em mobile) -->
    <button class="hamburger-btn" id="hamburgerBtn" aria-label="Abrir menu">
        <span></span>
        <span></span>
        <span></span>
    </button>

    <!-- Overlay (mobile) -->
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <main class="container-fluid min-vh-100 px-0">
        <div class="row flex-nowrap g-0">

            <!-- Sidebar -->
            <aside id="barraLateral" class="min-vh-100 bg-dark2 sidebar">

                <!-- Botão fechar (mobile) -->
                <button class="close-btn" id="closeBtn" aria-label="Fechar menu">&#10005;</button>

                <article class="sidebar-header p-4 m-1">
                    <img class="img-fluid mb-3" id="img-vh" src="img/icons/vh.png" alt="Viação Horizonte">
                    <div class="sidebar-brand-text">
                        <h1 class="text-white p-0 m-0 fw-normal fs-6">V I A Ç Ã O</h1>
                        <h1 class="text-yellow p-0 m-0 fw-bold fs-6">H O R I Z O N T E</h1>
                        <p class="text-white2 p-0 m-0 mt-3 fs-7">Transportando destinos</p>
                        <p class="text-white2 p-0 m-0 fs-7">conectando você</p>
                    </div>
                </article>

                <section class="bg-dark3 rounded-4 fs-6 sidebar-nav-section" id="bar">
                    <nav>
                        <ul class="nav flex-column">

                            <li class="nav-item">
                                <a class="nav-link text-white p-0 m-3 nav-item-link" href="/motorista">
                                    <img class="img-fluid nav-icon" src="img/icons/user (2).png" alt="Motoristas">
                                    <span class="nav-label">Motoristas</span>
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link p-0 m-3 text-white nav-item-link" href="/veiculo">
                                    <div class="troca-imagem">
                                        <img class="img-fluid img nav-icon" src="img/icons/bus (2).png" alt="Veículos">
                                    </div>
                                    <span class="nav-label">Veículos</span>
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-white p-0 m-3 nav-item-link" href="/rota">
                                    <img class="img-fluid nav-icon" src="img/icons/rotes (2).png" alt="Rotas">
                                    <span class="nav-label">Rotas</span>
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-white p-0 m-3 nav-item-link" href="/viagem">
                                    <img class="img-fluid nav-icon" src="img/icons/viagem (2).png" alt="Viagens">
                                    <span class="nav-label">Viagens</span>
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-white p-0 m-3 nav-item-link" href="#">
                                    <img class="img-fluid nav-icon" src="img/icons/chave-inglesa (2).png"
                                        alt="Manutenções">
                                    <span class="nav-label">Manutenções</span>
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-white p-0 m-3 nav-item-link" href="#">
                                    <img class="img-fluid nav-icon" src="img/icons/gasolina (2).png"
                                        alt="Abastecimento">
                                    <span class="nav-label">Abastecimento</span>
                                </a>
                            </li>
                        </ul>
                    </nav>
                </section>

            </aside>

            <!-- Conteúdo principal -->
            <section class="main-content bg-light flex-grow-1">

                <!-- TOPBAR -->
                <div class="topbar">
                    <div class="topbar-left">
                        <h2 class="topbar-title">Viagens</h2>
                    </div>

                    <form action="get">
                        <div class="topbar-search">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#aaa" stroke-width="2"
                                stroke-linecap="round">
                                <circle cx="11" cy="11" r="8" />
                                <line x1="21" y1="21" x2="16.65" y2="16.65" />
                            </svg>
                            <input type="text" id="campoPesquisa" placeholder="Pesquisar viagem...">
                            <button type="button" class="kbd-hint btn btn-light" id="btnPesquisar">Pesquisar</button>
                        </div>
                    </form>

                    <div class="topbar-right">
                        <div class="user-info">
                            <div class="user-avatar-placeholder">awa</div>
                            <div class="sidebar-brand-text">
                                <div class="user-name">Matheus Oliveira</div>
                                <div class="user-role">Supervisor</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- TOOLBAR -->
                <div class="vehicles-toolbar">
                    <button id="abrirModal" class="btn-add-vehicle">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2.5" stroke-linecap="round">
                            <line x1="12" y1="5" x2="12" y2="19" />
                            <line x1="5" y1="12" x2="19" y2="12" />
                        </svg>
                        Agendar Viagem
                    </button>
                    <button id="abrirModalEx" class="btn-dark btn">
                        Cancelar Viagem
                    </button>
                    <button id="abrirModalEdit" class="btn-outline-dark btn">
                        Alterar Status
                    </button>
                </div>

                <!-- GRID DE VIAGENS -->
                <div class="vehicles-grid" id="gridViagens">
                    <!-- Cards inseridos via JS -->
                </div>


                <!-- ===================== MODAL: AGENDAR VIAGEM =====================
                     Rota: POST /viagem/adicionar
                     Requer: id_rota, id_veiculo, id_motorista, data_viagem, horario_viagem, id_supervisor
                ================================================================ -->
                <div id="modal" class="modal">
                    <div class="modal-content">
                        <span id="fecharModal">&times;</span>
                        <h2 class="text-center">Agendar Viagem</h2>
                        <form class="text-center" id="formAdicionar">
                            <p>Preencha os dados para agendar uma nova viagem.</p>

                            <select name="id_rota" class="form-control my-3" required id="selectRota">
                                <option value="" disabled selected>Selecione a rota...</option>
                            </select>

                            <select name="id_veiculo" class="form-control my-3" required id="selectVeiculo">
                                <option value="" disabled selected>Selecione o veículo...</option>
                            </select>

                            <select name="id_motorista" class="form-control my-3" required id="selectMotorista">
                                <option value="" disabled selected>Selecione o motorista...</option>
                            </select>

                            <input type="date" name="data_viagem" class="form-control my-3" required>

                            <input type="time" name="horario_viagem" class="form-control my-3" required>

                            <button type="submit" class="btn btn-warning mt-2">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="2.5" stroke-linecap="round">
                                    <line x1="12" y1="5" x2="12" y2="19" />
                                    <line x1="5" y1="12" x2="19" y2="12" />
                                </svg>
                                Agendar Viagem
                            </button>
                        </form>
                    </div>
                </div>


                <!-- ===================== MODAL: CANCELAR VIAGEM =====================
                     Permite localizar uma viagem e cancelá-la.
                     Rota: POST /viagem/deletar
                ============================================================= -->
                <div id="modalEx" class="modal">
                    <div class="modal-content">
                        <span id="fecharModalEx">&times;</span>
                        <h2 class="text-center mb-3">Cancelar Viagem</h2>
                        <form class="text-center" id="formExcluir">
                            <p>Informe o ID da viagem para localizá-la.</p>
                            <input type="number" placeholder="ID da viagem..." name="id"
                                class="form-control" required id="inputIdCancelar">
                            <br>
                            <div id="resumoCancelar" style="display: none; text-align: left; margin: 15px 0; padding: 12px; background: #f5f5f5; border-radius: 8px;">
                                <p><strong>Origem:</strong> <span id="cancelarOrigem"></span></p>
                                <p><strong>Destino:</strong> <span id="cancelarDestino"></span></p>
                                <p><strong>Motorista:</strong> <span id="cancelarMotorista"></span></p>
                                <p><strong>Veículo:</strong> <span id="cancelarVeiculo"></span></p>
                                <p><strong>Data:</strong> <span id="cancelarData"></span></p>
                                <p><strong>Horário:</strong> <span id="cancelarHorario"></span></p>
                                <p><strong>Status:</strong> <span id="cancelarStatus"></span></p>
                            </div>
                            <button type="button" class="btn btn-outline-dark" id="btnBuscarCancelar" style="margin-bottom: 10px;">
                                Localizar Viagem
                            </button>
                            <button type="submit" class="btn btn-warning" id="btnConfirmarCancelar" style="display: none;">
                                Cancelar Viagem
                            </button>
                        </form>
                    </div>
                </div>


                <!-- ===================== MODAL: ALTERAR STATUS =====================
                     Permite localizar uma viagem e alterar seu status.
                     Lógica:
                     - Motorista: pode iniciar (Agendada → Em andamento) ou finalizar (Em andamento → Finalizada)
                     - Supervisor: pode cancelar (Agendada → Cancelada)
                     Rota: PUT /viagem/alterar-status
                ============================================================= -->
                <div id="modalEdit" class="modal">
                    <div class="modal-content">
                        <span id="fecharModalEdit">&times;</span>
                        <h2 class="text-center mb-3">Alterar Status da Viagem</h2>
                        <form class="text-center" id="formEditar">
                            <p>Informe o ID da viagem para localizá-la.</p>

                            <input type="number" name="id" class="form-control my-3"
                                placeholder="ID da viagem..." required id="inputIdStatus">

                            <button type="button" class="btn btn-outline-dark" id="btnBuscarStatus" style="margin-bottom: 10px;">
                                Localizar Viagem
                            </button>

                            <div id="resumoStatus" style="display: none; text-align: left; margin: 15px 0; padding: 12px; background: #f5f5f5; border-radius: 8px;">
                                <p><strong>Origem:</strong> <span id="statusOrigem"></span></p>
                                <p><strong>Destino:</strong> <span id="statusDestino"></span></p>
                                <p><strong>Motorista:</strong> <span id="statusMotorista"></span></p>
                                <p><strong>Veículo:</strong> <span id="statusVeiculo"></span></p>
                                <p><strong>Data:</strong> <span id="statusData"></span></p>
                                <p><strong>Horário:</strong> <span id="statusHorario"></span></p>
                                <p><strong>Status Atual:</strong> <span id="statusAtual"></span></p>
                            </div>

                            <div id="acoesBotoes" style="display: none; margin-top: 15px;">
                                <button type="button" class="btn btn-success" id="btnIniciar" style="display: none; width: 100%; margin-bottom: 8px;">
                                    Iniciar Viagem
                                </button>
                                <button type="button" class="btn btn-success" id="btnFinalizar" style="display: none; width: 100%; margin-bottom: 8px;">
                                    Finalizar Viagem
                                </button>
                                <button type="button" class="btn btn-danger" id="btnCancelarStatus" style="display: none; width: 100%;">
                                    Cancelar Viagem
                                </button>
                            </div>
                        </form>
                    </div>
                </div>


                <!-- ===================== MODAL: FEEDBACK ===================== -->
                <div id="erroPlaca" class="modal">
                    <div id="bgPop" class="modal-content">
                        <span id="fecharErroPlaca">&times;</span>
                        <h2 class="text-center mb-3 text-white" id="msgTitulo"></h2>
                        <p class="text-center text-white" id="msgErro"></p>
                        <button class="btn btn-dark text-light" id="fecharErroPlacaBtn">
                            Fechar
                        </button>
                    </div>
                </div>

            </section>
        </div>
    </main>

    <script src="js/viagens.js"></script>
</body>

</html>
