<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Painel Admin - Supervisores</title>
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>👤 Painel Admin</h1>
            <p>Gerenciar Supervisores do Sistema</p>
        </div>

        <div class="tabs">
            <button class="tab-button active" onclick="abrirAba('criar')">➕ Criar Supervisor</button>
            <button class="tab-button" onclick="abrirAba('listar')">📋 Listar Supervisores</button>
        </div>

        <div class="content">
            <!-- ABA 1: CRIAR SUPERVISOR -->
            <div id="criar" class="tab-content active">
                <div id="mensagem-criar"></div>

                <form id="formulario">
                    <div class="form-group">
                        <label for="nome">Nome Completo *</label>
                        <input type="text" id="nome" name="nome" required>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label for="cpf">CPF *</label>
                            <input type="text" id="cpf" name="cpf" placeholder="000.000.000-00" required>
                        </div>
                        <div class="form-group">
                            <label for="telefone">Telefone *</label>
                            <input type="text" id="telefone" name="telefone" placeholder="11999999999" required>
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="senha">Senha *</label>
                        <input type="password" id="senha" name="senha" required>
                    </div>

                    <button type="submit">Criar Supervisor</button>

                    <div class="loading" id="loading">
                        Criando supervisor... ⏳
                    </div>
                </form>
            </div>

            <!-- ABA 2: LISTAR SUPERVISORES -->
            <div id="listar" class="tab-content">
                <div id="mensagem-listar"></div>

                <div class="loading" id="loading-lista" style="display: block;">
                    Carregando supervisores... ⏳
                </div>

                <div id="supervisores-container" class="supervisores-list"></div>
            </div>

            <!-- BOTÃO DE LOGOUT (comum a ambas as abas) -->
            <button type="button" class="logout-btn" onclick="logout()">🚪 Logout</button>
        </div>
    </div>

    <!-- MODAL DE CONFIRMAÇÃO DE DELETE -->
    <div id="modalDelete" class="modal">
        <div class="modal-content">
            <div class="modal-header">⚠️ Confirmação</div>
            <div class="modal-body">
                Tem certeza que deseja deletar o supervisor <strong id="nomeSupervisor"></strong>?
            </div>
            <div class="modal-footer">
                <button class="btn-cancel" onclick="fecharModal()">Cancelar</button>
                <button class="btn-confirm" onclick="confirmarDelete()">Deletar</button>
            </div>
        </div>
    </div>

    <script src="/js/admin.js"></script>
</body>
</html>
