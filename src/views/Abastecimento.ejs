<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Abastecimento</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/Submenu.css">
</head>

<body>

<button class="hamburger-btn" id="hamburgerBtn">
    <span></span><span></span><span></span>
</button>

<div class="sidebar-overlay" id="sidebarOverlay"></div>

<main class="container-fluid min-vh-100 px-0">
<div class="row flex-nowrap g-0">

<aside id="barraLateral" class="min-vh-100 bg-dark2 sidebar">

    <button class="close-btn" id="closeBtn">&times;</button>

    <article class="sidebar-header p-4 m-1">
        <img class="img-fluid mb-3" id="img-vh" src="img/icons/vh.png">

        <div class="sidebar-brand-text">
            <h1 class="text-white fs-6">V I A Ç Ã O</h1>
            <h1 class="text-yellow fs-6">H O R I Z O N T E</h1>
            <p class="text-white2 fs-7">Transportando destinos</p>
        </div>
    </article>

    <section class="bg-dark3 rounded-4 sidebar-nav-section">
        <nav>
            <ul class="nav flex-column">

                <li class="nav-item">
                    <a class="nav-link text-white nav-item-link" href="/motoristas">Motoristas</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link text-white nav-item-link" href="/veiculos">Veículos</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link text-white nav-item-link" href="/rotas">Rotas</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link text-white nav-item-link" href="/viagens">Viagens</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link text-white nav-item-link active" href="/abastecimento">Abastecimento</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link text-white nav-item-link" href="/manutencao">Manutenção</a>
                </li>

            </ul>
        </nav>
    </section>
</aside>

<section class="main-content bg-light flex-grow-1">

    <div class="topbar">
        <h2 class="topbar-title">Abastecimento</h2>
    </div>

    <div class="vehicles-toolbar">

        <button id="btnAbrirCriar" class="btn-add-vehicle">
            Novo Abastecimento
        </button>

        <button id="btnListar" class="btn btn-dark">
            Atualizar Lista
        </button>

    </div>

    <div class="vehicles-grid" id="gridAbastecimento">

    </div>

</section>

</div>
</main>

<div id="modalCriar" class="modal">
    <div class="modal-content">
        <span id="fecharCriar">&times;</span>

        <h3>Criar Abastecimento</h3>

        <form id="formCriar">
            <input type="number" name="id_veiculo" class="form-control my-2" placeholder="ID veículo">
            <input type="number" step="0.01" name="litros" class="form-control my-2" placeholder="Litros">
            <input type="number" step="0.01" name="valor" class="form-control my-2" placeholder="Valor (R$)">
            <input type="date" name="data_abastecimento" class="form-control my-2">

            <button class="btn btn-warning w-100">Criar</button>
        </form>
    </div>
</div>

<div id="modalMsg" class="modal">
    <div class="modal-content">
        <span id="fecharMsg">&times;</span>

        <h4 id="msgTitulo"></h4>
        <p id="msgTexto"></p>

        <button class="btn btn-dark w-100">Fechar</button>
    </div>
</div>

<script src="/js/abastecimento.js"></script>
</body>
</html>